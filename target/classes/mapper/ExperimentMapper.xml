<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.digitaltwin.mapper.ExperimentMapper">

    <resultMap id="BaseResultMap" type="Experiment">
        <id     column="id"              property="id"/>
        <result column="name"            property="name"/>
        <result column="animal_type"     property="animalType"/>
        <result column="chemical_name"   property="chemicalName"/>
        <result column="simulation_mode" property="simulationMode"/>
        <result column="indicator_name"  property="indicatorName"/>
        <result column="target_organs"   property="targetOrgans"/>
        <result column="description"     property="description"/>
        <result column="status"          property="status"/>
        <result column="submitted_by"    property="submittedBy"/>
        <result column="reviewed_by"     property="reviewedBy"/>
        <result column="reviewed_time"   property="reviewedTime"/>
        <result column="review_comment"  property="reviewComment"/>
        <result column="created_time"    property="createdTime"/>
        <result column="updated_time"    property="updatedTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, animal_type, chemical_name, simulation_mode, indicator_name, target_organs, description,
        status, submitted_by, reviewed_by, reviewed_time, review_comment,
        created_time, updated_time
    </sql>

    <sql id="Where_Visible">
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <choose>
                <when test="isAdmin">
                </when>
                <otherwise>
                    AND (status = 'APPROVED' OR submitted_by = #{currentUserId})
                </otherwise>
            </choose>
        </where>
    </sql>

    <select id="countVisible" resultType="long">
        SELECT COUNT(*)
        FROM experiment
        <include refid="Where_Visible"/>
    </select>

    <select id="selectVisiblePage" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM experiment
        <include refid="Where_Visible"/>
        ORDER BY
        <choose>
            <when test="orderColumn == 'created_time'">created_time</when>
            <when test="orderColumn == 'updated_time'">updated_time</when>
            <otherwise>id</otherwise>
        </choose>
        <choose>
            <when test="orderDirection == 'ASC'"> ASC</when>
            <otherwise> DESC</otherwise>
        </choose>
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM experiment
        WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO experiment (
            name, animal_type, chemical_name, simulation_mode, indicator_name, target_organs, description,
            status, submitted_by, reviewed_by, reviewed_time, review_comment
        )
        VALUES (
            #{name}, #{animalType}, #{chemicalName}, #{simulationMode}, #{indicatorName}, #{targetOrgans}, #{description},
            #{status}, #{submittedBy}, #{reviewedBy}, #{reviewedTime}, #{reviewComment}
        )
    </insert>

    <update id="updateById">
        UPDATE experiment
        <set>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="animalType != null and animalType != ''">animal_type = #{animalType},</if>
            <if test="chemicalName != null and chemicalName != ''">chemical_name = #{chemicalName},</if>
            <if test="simulationMode != null and simulationMode != ''">simulation_mode = #{simulationMode},</if>
            <if test="indicatorName != null">indicator_name = #{indicatorName},</if>
            <if test="targetOrgans != null">target_organs = #{targetOrgans},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="submittedBy != null">submitted_by = #{submittedBy},</if>
            reviewed_by = #{reviewedBy},
            reviewed_time = #{reviewedTime},
            review_comment = #{reviewComment}
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE experiment
        SET status = #{status},
            reviewed_by = #{reviewedBy},
            reviewed_time = CURRENT_TIMESTAMP,
            review_comment = #{reviewComment}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM experiment WHERE id = #{id}
    </delete>

</mapper>
